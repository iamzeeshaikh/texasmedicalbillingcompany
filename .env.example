# ─────────────────────────────────────────────────────────────────────────────
# LOCAL SECRETS — never commit this file. .gitignore already excludes it.
# On Vercel/Netlify, set these same names in the project's Environment
# Variables UI; this file is not deployed.
# ─────────────────────────────────────────────────────────────────────────────

# SMTP transport for website form submissions (src/pages/api/contact.ts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=

# ⚠ Gmail requires an APP PASSWORD here, not your normal Google password.
# Your normal password will fail with "Username and Password not accepted".
# Create one at: https://myaccount.google.com/apppasswords
# (2-Step Verification must be ON for that page to appear.)
# It looks like 16 letters; paste it with or without spaces.
SMTP_PASS=

# Where form submissions are delivered.
SMTP_TO=

# ⚠ Gmail will only send as SMTP_FROM_EMAIL if that address is added and
# verified under Gmail → Settings → Accounts → "Send mail as". Until then
# Gmail silently rewrites the From to SMTP_USER, so mail arrives from the
# gmail.com address instead. Delivery still works either way — the visitor's
# address is set as Reply-To regardless, so replying reaches them.
SMTP_FROM_NAME=Texas Medical Billing Company
SMTP_FROM_EMAIL=info@texasmedicalbillingcompany.com

# ─────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────

# Overrides the built-in /api/contact endpoint with a third-party form service.
# Leave empty to use the SMTP endpoint above.
PUBLIC_FORM_ENDPOINT=

# Analytics — safe to expose (PUBLIC_ prefix ships to the browser by design).
PUBLIC_GA4_ID=
PUBLIC_CLARITY_ID=
PUBLIC_GSC_VERIFICATION=

# Set to true in a local build to reveal compliance ReviewFlag notices.
PUBLIC_SHOW_REVIEW_FLAGS=
