---
/**
 * Curated related-content cards. Feed from the entry's related* arrays —
 * never auto-link keyword occurrences or dump giant link lists.
 */
interface Props {
  heading?: string;
  links: { title: string; href: string; description?: string; badge?: string }[];
  alt?: boolean;
}
const { heading = 'Related Resources', links, alt = false } = Astro.props;
---

{
  links.length > 0 && (
    <section class={`section ${alt ? 'section-alt' : ''}`}>
      <div class="container-site">
        <h2 class="h2">{heading}</h2>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {links.map((link) => (
            <a href={link.href} class="card-link">
              {link.badge && <span class="badge-teal mb-3">{link.badge}</span>}
              <p class="font-semibold text-navy-900">{link.title}</p>
              {link.description && (
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{link.description}</p>
              )}
              <p class="mt-3 text-sm font-semibold text-teal-700">Learn more →</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
