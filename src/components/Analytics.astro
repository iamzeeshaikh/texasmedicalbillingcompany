---
/**
 * Privacy-conscious analytics loader.
 * All IDs come from environment variables (see ENVIRONMENT-VARIABLES.md);
 * nothing loads when the variables are unset. Event naming convention is
 * documented in DEPLOYMENT.md → Analytics events.
 */
import { ANALYTICS } from '../config/site';
---

{
  ANALYTICS.ga4Id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ANALYTICS.ga4Id}`}></script>
      <script is:inline define:vars={{ ga4Id: ANALYTICS.ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', ga4Id, { anonymize_ip: true });
      </script>
    </>
  )
}

{
  ANALYTICS.clarityId && (
    <script is:inline define:vars={{ clarityId: ANALYTICS.clarityId }}>
      (function (c, l, a, r, i, t, y) {
        c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
        t = l.createElement(r); t.async = 1; t.src = 'https://www.clarity.ms/tag/' + i;
        y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
      })(window, document, 'clarity', 'script', clarityId);
    </script>
  )
}

<script>
  // Delegated analytics event hooks. Elements opt in with data-analytics.
  // Naming convention: cta_click, form_submit, form_success, phone_click,
  // email_click, consultation_click (see documentation).
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement).closest<HTMLElement>('[data-analytics]');
    if (!el) return;
    const eventName = el.dataset.analytics;
    if (!eventName) return;
    const w = window as typeof window & { gtag?: (...args: unknown[]) => void };
    if (typeof w.gtag === 'function') {
      w.gtag('event', eventName, {
        cta_id: el.dataset.cta ?? undefined,
        form_id: el.dataset.form ?? undefined,
        link_url: el.getAttribute('href') ?? undefined,
      });
    }
  });
</script>
