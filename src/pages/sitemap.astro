---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { services, specialties, locations, software, payers, solutions, costPages, comparisons } from '../data';
import { breadcrumbSchema } from '../lib/schema';
import { canonicalUrl } from '../lib/url';

const guides = (await getCollection('guides')).sort((a, b) => a.data.title.localeCompare(b.data.title));
const posts = (await getCollection('blog')).sort((a, b) => a.data.title.localeCompare(b.data.title));

const sections: { heading: string; links: { label: string; href: string }[] }[] = [
  {
    heading: 'Company',
    links: [
      { label: 'Home', href: '/' },
      { label: 'About Us', href: '/about/' },
      { label: 'Why Choose Us', href: '/why-us/' },
      { label: 'Our Process', href: '/our-process/' },
      { label: 'HIPAA & Security', href: '/hipaa-and-security/' },
      { label: 'Pricing', href: '/pricing/' },
      { label: 'FAQ', href: '/faq/' },
      { label: 'Careers', href: '/careers/' },
      { label: 'Case Studies', href: '/case-studies/' },
      { label: 'Contact', href: '/contact/' },
      { label: 'Free Billing Assessment', href: '/free-billing-assessment/' },
      { label: 'Schedule a Consultation', href: '/schedule-a-consultation/' },
      { label: 'Resources', href: '/resources/' },
    ],
  },
  {
    heading: 'Services',
    links: [
      { label: 'All Services', href: '/services/' },
      ...services.map((s) => ({ label: s.title, href: `/services/${s.slug}/` })),
    ],
  },
  {
    heading: 'Specialties',
    links: [
      { label: 'All Specialties', href: '/specialties/' },
      ...[...specialties]
        .sort((a, b) => a.specialtyName.localeCompare(b.specialtyName))
        .map((s) => ({ label: s.specialtyName, href: `/specialties/${s.slug}/` })),
    ],
  },
  {
    heading: 'Texas Locations',
    links: [
      { label: 'All Locations', href: '/locations/' },
      ...[...locations]
        .sort((a, b) => a.cityName.localeCompare(b.cityName))
        .map((l) => ({ label: l.cityName, href: `/locations/${l.slug}/` })),
    ],
  },
  {
    heading: 'Software Support',
    links: [
      { label: 'All Software', href: '/software/' },
      ...software.map((s) => ({ label: s.platformName, href: `/software/${s.slug}/` })),
    ],
  },
  {
    heading: 'Payer Resources',
    links: [
      { label: 'All Payer Resources', href: '/payers/' },
      ...payers.map((p) => ({ label: p.title, href: `/payers/${p.slug}/` })),
    ],
  },
  {
    heading: 'Problems We Solve',
    links: [
      { label: 'All Solutions', href: '/solutions/' },
      ...solutions.map((s) => ({ label: s.title, href: `/solutions/${s.slug}/` })),
    ],
  },
  {
    heading: 'Cost Resources',
    links: [
      { label: 'All Cost Resources', href: '/cost/' },
      ...costPages.map((c) => ({ label: c.title, href: `/cost/${c.slug}/` })),
    ],
  },
  {
    heading: 'Comparisons',
    links: [
      { label: 'All Comparisons', href: '/compare/' },
      ...comparisons.map((c) => ({ label: c.title, href: `/compare/${c.slug}/` })),
    ],
  },
  {
    heading: 'Knowledge Center',
    links: [
      { label: 'All Guides', href: '/guides/' },
      ...guides.map((g) => ({ label: g.data.title, href: `/guides/${g.id}/` })),
    ],
  },
  {
    heading: 'Blog',
    links: [
      { label: 'All Articles', href: '/blog/' },
      ...posts.map((p) => ({ label: p.data.title, href: `/blog/${p.id}/` })),
    ],
  },
  {
    heading: 'Legal & Editorial',
    links: [
      { label: 'Privacy Policy', href: '/privacy-policy/' },
      { label: 'Terms & Conditions', href: '/terms/' },
      { label: 'Accessibility Statement', href: '/accessibility/' },
      { label: 'Cookie Policy', href: '/cookie-policy/' },
      { label: 'Editorial Policy', href: '/editorial-policy/' },
      { label: 'Content Review Process', href: '/content-review-process/' },
      { label: 'Corrections Policy', href: '/corrections-policy/' },
    ],
  },
];
---

<BaseLayout
  title="Sitemap | Texas Medical Billing Company"
  description="Complete HTML sitemap of texasmedicalbillingcompany.com: services, specialties, locations, guides, resources, and company pages."
  canonicalPath="/sitemap/"
  schema={[breadcrumbSchema([{ name: 'Home', url: canonicalUrl('/') }, { name: 'Sitemap' }])]}
>
  <PageHero h1="Sitemap" breadcrumbs={[{ name: 'Sitemap' }]} />

  <section class="section">
    <div class="container-site">
      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
        {
          sections.map((section) => (
            <div>
              <h2 class="h3 border-b border-slate-200 pb-2">{section.heading}</h2>
              <ul class="mt-3 space-y-1.5 text-sm">
                {section.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-slate-600 hover:text-teal-700 hover:underline">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
