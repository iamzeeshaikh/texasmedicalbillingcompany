---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaSection from '../../components/CtaSection.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { services, solutions } from '../../data';
import { breadcrumbSchema, articleSchema } from '../../lib/schema';
import { canonicalUrl } from '../../lib/url';
import { DISCLAIMER } from '../../config/site';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const path = `/guides/${guide.id}/`;
const data = guide.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const toc = headings.filter((h) => h.depth === 2);

const relatedLinks = [
  ...data.relatedServices
    .map((slug) => services.find((s) => s.slug === slug))
    .filter((s) => !!s)
    .map((s) => ({ title: s.title, href: `/services/${s.slug}/`, badge: 'Service' })),
  ...data.relatedSolutions
    .map((slug) => solutions.find((s) => s.slug === slug))
    .filter((s) => !!s)
    .map((s) => ({ title: s.title, href: `/solutions/${s.slug}/`, badge: 'Problem We Solve' })),
  ...data.relatedGuides.slice(0, 3).map((slug) => ({
    title: slug.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    href: `/guides/${slug}/`,
    badge: 'Guide',
  })),
].slice(0, 6);

const schema = [
  breadcrumbSchema([
    { name: 'Home', url: canonicalUrl('/') },
    { name: 'Guides', url: canonicalUrl('/guides/') },
    { name: data.title },
  ]),
  articleSchema({
    url: canonicalUrl(path),
    headline: data.title,
    description: data.metaDescription,
    datePublished: data.publishedDate.toISOString(),
    dateModified: (data.updatedDate ?? data.publishedDate).toISOString(),
  }),
];
---

<BaseLayout
  title={data.seoTitle}
  description={data.metaDescription}
  canonicalPath={path}
  noindex={!data.indexable}
  ogType="article"
  schema={schema}
  datePublished={data.publishedDate.toISOString()}
  dateModified={(data.updatedDate ?? data.publishedDate).toISOString()}
>
  <PageHero
    eyebrow="Knowledge Center"
    h1={data.title}
    lead={data.summary}
    breadcrumbs={[{ name: 'Guides', href: '/guides/' }, { name: data.title }]}
  />

  <section class="section">
    <div class="container-site grid gap-12 lg:grid-cols-4">
      <aside class="order-2 space-y-6 lg:order-1">
        {
          toc.length > 1 && (
            <nav class="card sticky top-24" aria-label="Table of contents">
              <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">On this page</p>
              <ul class="mt-3 space-y-2 text-sm">
                {toc.map((h) => (
                  <li>
                    <a href={`#${h.slug}`} class="text-slate-600 hover:text-teal-700">{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>

      <div class="order-1 lg:order-2 lg:col-span-3">
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-1 border-b border-slate-100 pb-4 text-xs text-slate-500">
          <span>Published: {fmt(data.publishedDate)}</span>
          {data.updatedDate && <span>Updated: {fmt(data.updatedDate)}</span>}
          {data.reviewedDate && <span>Last reviewed: {fmt(data.reviewedDate)}</span>}
          <span>By: Texas Medical Billing Company Editorial</span>
        </div>

        <article class="prose-site">
          <Content />
        </article>

        {
          data.sources.length > 0 && (
            <div class="mt-10 rounded-(--radius-card) border border-slate-200 bg-sand-50 p-6">
              <h2 class="h3">Sources</h2>
              <ul class="mt-3 space-y-1.5 text-sm">
                {data.sources.map((source) => (
                  <li>
                    <a href={source.url} rel="noopener nofollow" target="_blank" class="text-teal-700 underline">
                      {source.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <p class="mt-8 text-xs leading-relaxed text-slate-500">{DISCLAIMER}</p>
      </div>
    </div>
  </section>

  {relatedLinks.length > 0 && <RelatedLinks heading="Related Pages" links={relatedLinks} alt />}

  <CtaSection
    heading="Reading about the problem? We fix it daily."
    ctaId={`guide_${guide.id}`}
  />
</BaseLayout>
