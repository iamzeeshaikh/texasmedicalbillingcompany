---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaSection from '../../components/CtaSection.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import ReviewFlag from '../../components/ReviewFlag.astro';
import { payers, services } from '../../data';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { canonicalUrl } from '../../lib/url';
import { PAYER_DISCLAIMER, DISCLAIMER } from '../../config/site';

export function getStaticPaths() {
  return payers.map((payer) => ({ params: { slug: payer.slug }, props: { payer } }));
}

const { payer } = Astro.props;
const path = `/payers/${payer.slug}/`;

const serviceLinks = payer.relatedServices
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s) => !!s)
  .map((s) => ({ title: s.title, href: `/services/${s.slug}/`, badge: 'Service' }));

const schema = [
  breadcrumbSchema([
    { name: 'Home', url: canonicalUrl('/') },
    { name: 'Payer Resources', url: canonicalUrl('/payers/') },
    { name: payer.title },
  ]),
  faqSchema(payer.faqs),
];
---

<BaseLayout
  title={payer.seoTitle}
  description={payer.metaDescription}
  canonicalPath={path}
  noindex={!payer.indexable}
  schema={schema}
>
  {payer.complianceReviewRequired && <ReviewFlag topics={payer.complianceTopics} note="Verify payer facts and source links before launch." />}

  <PageHero
    eyebrow="Payer Resources · Educational"
    h1={payer.h1}
    lead={payer.summary}
    breadcrumbs={[{ name: 'Payer Resources', href: '/payers/' }, { name: payer.title }]}
  />

  <section class="border-b border-slate-100 bg-sand-50 py-4">
    <div class="container-site">
      <p class="text-xs leading-relaxed text-slate-600">
        <strong>Disclaimer:</strong> {PAYER_DISCLAIMER}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-site grid gap-12 lg:grid-cols-3">
      <div class="prose-site lg:col-span-2">
        {payer.intro.map((para) => <p class="text-lg">{para}</p>)}

        {
          payer.sections.map((section) => (
            <>
              <h2>{section.heading}</h2>
              {section.body.map((para) => <p>{para}</p>)}
              {section.bullets && (
                <ul>
                  {section.bullets.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </>
          ))
        }

        <h2>Sources</h2>
        <ul>
          {
            payer.sources.map((source) => (
              <li>
                <a href={source.url} rel="noopener nofollow" target="_blank">
                  {source.label}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="text-sm text-slate-500">
          Source links are provided for reference and verified at publication; payer policies change
          frequently — always confirm current rules with official sources.
        </p>
      </div>

      <aside class="space-y-6">
        <div class="card bg-navy-900 text-white">
          <p class="font-bold">Struggling with {payer.payerName} claims?</p>
          <p class="mt-2 text-sm text-navy-200">
            Our team works this payer’s rules daily. Get an assessment of where your claims stand.
          </p>
          <a href="/free-billing-assessment/" class="btn-accent mt-4 w-full" data-analytics="cta_click" data-cta={`payer_${payer.slug}`}>
            Request a Free Billing Assessment
          </a>
        </div>
        <div class="card">
          <p class="text-sm font-semibold text-navy-900">Related knowledge center guides</p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href="/guides/insurance-eligibility-verification/" class="text-teal-700 underline">Eligibility verification guide</a></li>
            <li><a href="/guides/denial-management/" class="text-teal-700 underline">Denial management guide</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <FaqSection faqs={payer.faqs} heading={`${payer.payerName} Billing FAQs`} />

  <RelatedLinks heading="Services That Help With This Payer" links={serviceLinks} alt />

  <section class="py-6">
    <div class="container-site">
      <p class="text-xs leading-relaxed text-slate-500">{DISCLAIMER}</p>
    </div>
  </section>

  <CtaSection ctaId={`payer_cta_${payer.slug}`} />
</BaseLayout>
