---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaSection from '../../components/CtaSection.astro';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';
import { canonicalUrl } from '../../lib/url';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);

const categoryLabels: Record<string, string> = {
  'revenue-cycle': 'Revenue Cycle',
  'practice-management': 'Practice Management',
  'payer-news': 'Payer News',
  'texas-healthcare': 'Texas Healthcare',
};
const categories = [...new Set(posts.map((p) => p.data.category))];

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const schema = [
  breadcrumbSchema([{ name: 'Home', url: canonicalUrl('/') }, { name: 'Blog' }]),
  itemListSchema(posts.map((p) => ({ name: p.data.title, url: canonicalUrl(`/blog/${p.id}/`) }))),
];
---

<BaseLayout
  title="Blog & Insights | Texas Medical Billing Company"
  description="Practical writing on medical billing, revenue cycle operations, and Texas practice management — problems worth solving, explained without filler."
  canonicalPath="/blog/"
  schema={schema}
>
  <PageHero
    eyebrow="Blog & Insights"
    h1="Blog and Insights"
    lead="Practical writing on the problems Texas practices actually face — no filler posts, no keyword mush, and an RSS feed for readers who prefer it."
    breadcrumbs={[{ name: 'Blog' }]}
  />

  <section class="section">
    <div class="container-site">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-sm font-medium text-slate-500">Categories:</span>
        {
          categories.map((cat) => (
            <a
              href={`/blog/category/${cat}/`}
              class="rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-xs font-medium text-navy-900 hover:border-teal-300 hover:bg-teal-50/40"
            >
              {categoryLabels[cat]}
            </a>
          ))
        }
        <a href="/rss.xml" class="ml-auto text-xs font-semibold text-teal-700 underline">RSS feed</a>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="card-link flex flex-col">
              <p class="text-xs font-semibold uppercase tracking-widest text-teal-700">
                {categoryLabels[post.data.category]}
              </p>
              <p class="mt-2 font-semibold text-navy-900">{post.data.title}</p>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">
                {post.data.summary.length > 140 ? post.data.summary.slice(0, 140) + '…' : post.data.summary}
              </p>
              <p class="mt-4 text-xs text-slate-400">{fmt(post.data.publishedDate)}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection ctaId="blog_hub" />
</BaseLayout>
